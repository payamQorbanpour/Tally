# Dependencies
node_modules

# Build / output
dist
build
web-build
.turbo
.cache

# Expo
.expo/
expo-env.d.ts

# Metro / watchman
.metro-health-check*

# Env and secrets (never commit)
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Test / coverage
coverage
.nyc_output

# TypeScript
*.tsbuildinfo

# Android / iOS — fully ignored. The native projects are regenerated by
# `npx expo prebuild` from `app.json` + config plugins, and EAS / local
# `expo run:ios|android` rebuilds them automatically. If you ever need
# to hand-edit native files, de-ignore selectively (or commit them)
# rather than dropping these rules wholesale.
ios/
android/

# Signing material — never commit, even when native folders are tracked
# during a debug session.
*.jks
*.p8
*.p12
*.keystore
*.key
ios.zip
*.hprof

# Optional local config
*.local

# Misc
.expo-shared/

# Backup files left behind by icon / asset generators
*.bak

# Supabase CLI local state (linked project ref, pooler URL with creds)
supabase/.temp/

# Claude
.claude
.serena

# Python
.venv

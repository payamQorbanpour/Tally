{
  "expo": {
    "name": "Tally",
    "slug": "tally",
    "scheme": "tally",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Tally-Slogan.png",
      "resizeMode": "contain",
      "backgroundColor": "#123635"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.payamqorbanpour.tally",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:tally-bills-app.vercel.app"],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Tally needs access to your photos to let you choose a group icon.",
        "NSCameraUsageDescription": "Tally uses the camera to scan receipts and automatically extract expense details using AI.",
        "NSMicrophoneUsageDescription": "Tally uses the microphone to record a short voice description of a bill, which is sent to AI to extract expenses.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E494E"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.payamqorbanpour.tally",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tally-bills-app.vercel.app",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "tally-bills-app.vercel.app",
              "pathPrefix": "/expense"
            },
            {
              "scheme": "https",
              "host": "tally-bills-app.vercel.app",
              "pathPrefix": "/auth/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-sqlite",
      "expo-iap",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tally needs access to your photos to let you choose a group icon.",
          "cameraPermission": "Tally uses the camera to scan receipts and automatically extract expense details using AI.",
          "microphonePermission": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Tally uses the microphone to record a short voice description of a bill, which is sent to AI to extract expenses."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tally uses the camera to scan QR codes for group invites and to scan receipts for expense extraction.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "note": "Set SENTRY_ORG, SENTRY_PROJECT, and SENTRY_AUTH_TOKEN env vars (locally and in EAS) so source maps are uploaded on each build. The DSN itself is read at runtime from EXPO_PUBLIC_SENTRY_DSN."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8d9cad29-e4ee-4876-9677-27c69ad14f2b"
      }
    },
    "owner": "payamqorbanpours-organization"
  }
}

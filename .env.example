# Copy to `.env` in this folder and fill in. `.env` is gitignored.
# EAS/CI: set the same EXPO_PUBLIC_* in your project’s Environment (no file needed on the build machine).

# Required for cloud sync (Supabase dashboard → Project settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional
# EXPO_PUBLIC_SUPABASE_ENABLE_SYNC=0
# EXPO_PUBLIC_POWERSYNC_ENABLE_SYNC=0
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT=
# EXPO_PUBLIC_OPENAI_API_KEY=
# EXPO_PUBLIC_OPENAI_RECEIPT_MODEL=gpt-4o-mini
# EXPO_PUBLIC_TALLY_RECEIPT_PARSE_URL=

# Premium (native App Store / Play): comma-separated subscription product IDs (same SKU on both stores when possible).
# Leave unset for local dev — cloud sync + AI receipt stay unlocked without IAP.
# EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS=com.payamqorbanpour.tally.premium
# Optional: Edge Function slug if not using default `sync-apple-subscription`
# EXPO_PUBLIC_SYNC_APPLE_SUBSCRIPTION_SLUG=sync-apple-subscription

# Supabase Edge Function `sync-apple-subscription` secrets (Dashboard → Edge Functions → Secrets):
# APP_STORE_CONNECT_P8   = contents of App Store Connect API .p8 private key (escape newlines as \n in the secret UI)
# APP_STORE_KEY_ID       = Key ID from App Store Connect → Users and Access → Keys
# APP_STORE_ISSUER_ID    = Issuer ID from App Store Connect
# APPLE_BUNDLE_ID        = com.payamqorbanpour.tally
# APPLE_PREMIUM_PRODUCT_IDS = same comma-separated list as EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS

# Copy to `.env` in this folder and fill in. `.env` is gitignored.
# EAS/CI: set the same EXPO_PUBLIC_* in your project’s Environment (no file needed on the build machine).

# Required for cloud sync — any Supabase-compatible backend (the app uses the Supabase JS SDK internally).
# From the Supabase dashboard: Project settings → API → Project URL and anon key.
EXPO_PUBLIC_SYNC_URL=
EXPO_PUBLIC_SYNC_ANON_KEY=

# Optional
# EXPO_PUBLIC_SYNC_ENABLED=0              # set to "0" to force offline-only builds
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT=

# --- Group invite share / QR ---
# Public web landing page that resolves group invites. The QR code shown in
# the in-app Share screen encodes `${EXPO_PUBLIC_INVITE_BASE_URL}/<token>`.
# The page should: (a) on mobile, redirect to `tally://group-invite?token=…`
# so the app opens directly, (b) fall back to App Store / Play Store + an
# "Open in web app" link, (c) on desktop, just open the web app.
# Leave unset to fall back to the raw `tally://` deep link in the QR.
# EXPO_PUBLIC_INVITE_BASE_URL=https://example.com/join

# Path used by the in-app deep link handler. Defaults to `tally://group-invite`.
# Override only if you change the URL scheme in app.json.
# EXPO_PUBLIC_INVITE_DEEP_LINK=tally://group-invite
# EXPO_PUBLIC_OPENAI_API_KEY=
# EXPO_PUBLIC_OPENAI_RECEIPT_MODEL=gpt-4o-mini
# EXPO_PUBLIC_OPENAI_WHISPER_MODEL=whisper-1
# EXPO_PUBLIC_TALLY_RECEIPT_PARSE_URL=

# Speech-to-text (for the AI voice expense flow). Defaults target ElevenLabs Scribe.
# Override EXPO_PUBLIC_STT_ENDPOINT_URL for other providers (the request uses the `xi-api-key`
# header and a `model_id` form field, so the target endpoint must accept that shape).
# EXPO_PUBLIC_STT_API_KEY=
# EXPO_PUBLIC_STT_MODEL=scribe_v1
# EXPO_PUBLIC_STT_ENDPOINT_URL=https://api.elevenlabs.io/v1/speech-to-text

# AI provider (OpenAI-compatible) — used for receipt-image OCR, expense description parsing,
# and category classification. Paste the URL prefix up to (but not including) `/chat/completions`.
# Example — gateway format (model + token embedded in the path, no API key needed):
EXPO_PUBLIC_AI_BASE_URL=https://example.com/v1
EXPO_PUBLIC_AI_MODEL=Qwen3-30B-A3B
# Example — OpenAI-style endpoint (requires a separate Bearer key):
# EXPO_PUBLIC_AI_BASE_URL=https://api.openai.com/v1
# EXPO_PUBLIC_AI_API_KEY=
# EXPO_PUBLIC_AI_MODEL=gpt-4o-mini
# Example — Groq Cloud (Llama 4 Scout supports vision; good for receipt OCR too):
# EXPO_PUBLIC_AI_BASE_URL=https://api.groq.com/openai/v1
# EXPO_PUBLIC_AI_API_KEY=
# EXPO_PUBLIC_AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Optional: use a different vision model for receipt image parsing (falls back to EXPO_PUBLIC_AI_MODEL).
# EXPO_PUBLIC_AI_RECEIPT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- AI prompt overrides (optional) ---
# Leave unset to use the built-in defaults. Dotenv supports real newlines inside
# a double-quoted value — but every inner double-quote MUST be escaped as \".
# Placeholders in the expense prompt: {currency}, {participants}.
EXPO_PUBLIC_AI_EXPENSE_PROMPT="You are a financial parsing assistant. Convert natural language into strictly validated JSON for expense tracking. Context: Default Currency: {currency}. Allowed Participants: {participants}. Instructions: (1) Multiple Expenses — if the description mentions several distinct transactions, return ONE entry per transaction in the expenses array; never merge unrelated transactions. (2) Entity Resolution — prefer names from the provided participant list (copy them exactly); if the description clearly introduces a new person who is NOT in the list, keep the new name verbatim (the app will create that person); for ambiguous names use best judgement but lower the confidence score. (3) Split Logic — \"split equally\" divides the amount evenly across the people involved; if specific amounts are mentioned for some people, the remainder goes to whoever \"paid for the rest\". (4) Validation — for each expense the sum of splits[].amount must equal amount (within 0.01). (5) Formatting — amounts are decimal numbers in major units, never strings. (6) \"payer\" and every \"person\" must be a single human name; prefer names from the participant list, otherwise use the exact new name the description introduced. Return ONLY a JSON object (no markdown) with this shape: { \"currency\": \"ISO Code\" or null, \"confidence\": \"high\"|\"medium\"|\"low\", \"reasoning\": \"short explanation of how splits were calculated\", \"expenses\": [ { \"description\": string, \"amount\": number, \"payer\": string, \"splits\": [ { \"person\": string, \"amount\": number } ] } ] }"
EXPO_PUBLIC_AI_CATEGORY_PROMPT="Classify the expense title into exactly one of: food, snack, drink, home, transport, general. Reply with ONLY {\"category\":\"<id>\"}."

# Premium (native App Store / Play): comma-separated subscription product IDs (same SKU on both stores when possible).
# Leave unset for local dev — cloud sync + AI receipt stay unlocked without IAP.
# EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS=com.payamqorbanpour.tally.premium
# Optional: Edge Function slug if not using default `sync-apple-subscription`
# EXPO_PUBLIC_SYNC_APPLE_SUBSCRIPTION_SLUG=sync-apple-subscription

# Supabase Edge Function `sync-apple-subscription` secrets (Dashboard → Edge Functions → Secrets):
# APP_STORE_CONNECT_P8   = contents of App Store Connect API .p8 private key (escape newlines as \n in the secret UI)
# APP_STORE_KEY_ID       = Key ID from App Store Connect → Users and Access → Keys
# APP_STORE_ISSUER_ID    = Issuer ID from App Store Connect
# APPLE_BUNDLE_ID        = com.payamqorbanpour.tally
# APPLE_PREMIUM_PRODUCT_IDS = same comma-separated list as EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS

# Copy to `.env` in this folder and fill in. `.env` is gitignored.
# EAS/CI: set the same EXPO_PUBLIC_* in your project’s Environment (no file needed on the build machine).

# Required for cloud sync — any Supabase-compatible backend (the app uses the Supabase JS SDK internally).
# From the Supabase dashboard: Project settings → API → Project URL and anon key.
EXPO_PUBLIC_SYNC_URL=
EXPO_PUBLIC_SYNC_ANON_KEY=

# Optional
# EXPO_PUBLIC_SYNC_ENABLED=0              # set to "0" to force offline-only builds
# Used ONLY for email confirmation / password-reset links (user clicks from
# their inbox → lands on this URL). DO NOT point this at the OAuth flow —
# Google / Apple sign-in always redirect back to the app via the `tally://`
# scheme so the system browser hands control back to the app.
# EXPO_PUBLIC_AUTH_EMAIL_REDIRECT=
# OAuth landing for the WEB build only. On native, the app scheme is used
# unconditionally; this var is ignored on iOS / Android.
# EXPO_PUBLIC_AUTH_OAUTH_REDIRECT=
# Show the "Continue with Google" button on the auth screen. Off by default —
# only flip on once Supabase → Authentication → Providers → Google is configured
# (Google Cloud Console OAuth client ID + secret pasted into the dashboard).
# EXPO_PUBLIC_AUTH_GOOGLE_ENABLED=1
# Show the "Continue with Apple" button. App Store enforces a parity rule:
# any iOS build that offers Google MUST also offer Apple, or the review fails.
# Backend setup needed first: Supabase → Authentication → Providers → Apple
# (Service ID + Apple Team ID + key ID + .p8). The native iOS sheet also
# requires `ios.usesAppleSignIn: true` in app.json (already set) plus a real
# rebuild — `expo-apple-authentication` is a native module so the dev client
# must be regenerated after `npm install` (run `npx expo prebuild` then EAS).
# EXPO_PUBLIC_AUTH_APPLE_ENABLED=1

# --- Group invite share / QR ---
# Public web landing page that resolves group invites. The QR code shown in
# the in-app Share screen encodes `${EXPO_PUBLIC_INVITE_BASE_URL}/<token>`.
# The page should: (a) on mobile, redirect to `tally://group-invite?token=…`
# so the app opens directly, (b) fall back to App Store / Play Store + an
# "Open in web app" link, (c) on desktop, just open the web app.
# Leave unset to fall back to the raw `tally://` deep link in the QR.
# EXPO_PUBLIC_INVITE_BASE_URL=https://example.com/join

# Path used by the in-app deep link handler. Defaults to `tally://group-invite`.
# Override only if you change the URL scheme in app.json.
# EXPO_PUBLIC_INVITE_DEEP_LINK=tally://group-invite

# Pass product IDs (one-time, non-consumable IAPs). Each pass has a base SKU
# (initial purchase, full duration) and a cheaper "extend" SKU surfaced in the
# expired-pass prompt. Leave unset for local dev / web — pass purchases will
# fall back to the web checkout URL, or stay disabled if that's also unset.
#
# Night Out Pass — 24h of premium tools, $1.99 buy / $0.99 extend
# EXPO_PUBLIC_NIGHT_OUT_PASS_ID=com.payamqorbanpour.tally.pass.night
# EXPO_PUBLIC_NIGHT_OUT_EXTEND_ID=com.payamqorbanpour.tally.pass.night.extend
#
# Trip Pass — 7 days of premium tools, $5.99 buy / $2.99 extend
# EXPO_PUBLIC_TRIP_PASS_ID=com.payamqorbanpour.tally.pass.trip
# EXPO_PUBLIC_TRIP_EXTEND_ID=com.payamqorbanpour.tally.pass.trip.extend
#
# Explorer Pass — 30 days of premium tools, $14.99 buy / $7.99 extend
# EXPO_PUBLIC_EXPLORER_PASS_ID=com.payamqorbanpour.tally.pass.explorer
# EXPO_PUBLIC_EXPLORER_EXTEND_ID=com.payamqorbanpour.tally.pass.explorer.extend
#
# Legacy: comma-separated subscription IDs from the previous pricing model.
# Existing subscribers stay grandfathered (the app still detects their
# subscription via expo-iap). New builds should leave this unset.
# EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS=com.payamqorbanpour.tally.premium
# Optional: Edge Function slug if not using default `sync-apple-subscription`
# EXPO_PUBLIC_SYNC_APPLE_SUBSCRIPTION_SLUG=sync-apple-subscription
# Optional: external web checkout page (e.g. Stripe Checkout / Paddle / your own site).
# Shown on the plans screen as a fallback CTA when in-app purchase isn't
# available (web builds, dev builds without SKUs, etc.). Must be http(s).
# EXPO_PUBLIC_SUBSCRIPTION_URL=https://example.com/tally-passes

# --- Sentry error monitoring ---
# Runtime DSN, baked into the JS bundle. Get it from Sentry:
#   Settings → Projects → <project> → Client Keys (DSN). It's safe to expose
#   (it can only ingest events, not read them). Leave unset to disable.
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@o0.ingest.sentry.io/0
#
# BUILD-TIME ONLY — never EXPO_PUBLIC_*. Required by the
# `@sentry/react-native/expo` config plugin to upload source maps + release
# artifacts on each native build. Set these in your shell (local dev),
# `eas env:create` (EAS), or CI secrets. Never commit real values.
# SENTRY_ORG=<org-slug>
# SENTRY_PROJECT=<project-slug>
# SENTRY_AUTH_TOKEN=<token with project:write + project:releases scopes>
# Optional self-hosted Sentry URL (defaults to https://sentry.io/).
# SENTRY_URL=https://sentry.io/

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS (NEVER put these in `.env` / `EXPO_PUBLIC_*`)
#
# Anything that costs money or grants account access lives as Supabase project
# secrets so it cannot be extracted from the shipped JS bundle. Set them via:
#   supabase secrets set NAME=value
# (or in the Supabase Dashboard → Edge Functions → <function> → Secrets).
#
# `ai-proxy` Edge Function secrets — used for receipt OCR, expense-description
# parsing, category classification, and audio transcription. Set at least one
# chat provider (AI_BASE_URL+AI_API_KEY, OR OPENAI_API_KEY) and one STT
# provider (STT_API_KEY for ElevenLabs, OR OPENAI_API_KEY for Whisper).
#
#   AI_BASE_URL              e.g. https://api.groq.com/openai/v1
#   AI_API_KEY               bearer token for the chat provider
#   AI_MODEL                 default chat model id (e.g. meta-llama/llama-4-scout-17b-16e-instruct)
#   AI_RECEIPT_MODEL         optional vision model override (falls back to AI_MODEL)
#   OPENAI_API_KEY           OpenAI fallback (vision / Whisper / classify)
#   OPENAI_RECEIPT_MODEL     OpenAI vision model id (default gpt-4o-mini)
#   OPENAI_WHISPER_MODEL     OpenAI STT model id (default whisper-1)
#   STT_API_KEY              ElevenLabs Scribe api key
#   STT_ENDPOINT_URL         STT endpoint (default https://api.elevenlabs.io/v1/speech-to-text)
#   STT_MODEL                STT model id (default scribe_v1)
#   AI_EXPENSE_PROMPT        optional system-prompt override (placeholders {currency}, {participants})
#   AI_CATEGORY_PROMPT       optional category-classifier system-prompt override
#
# `sync-apple-subscription` Edge Function secrets:
#   APP_STORE_CONNECT_P8     = contents of App Store Connect API .p8 private key (escape newlines as \n in the secret UI)
#   APP_STORE_KEY_ID         = Key ID from App Store Connect → Users and Access → Keys
#   APP_STORE_ISSUER_ID      = Issuer ID from App Store Connect
#   APPLE_BUNDLE_ID          = com.payamqorbanpour.tally
#   APPLE_PREMIUM_PRODUCT_IDS = same comma-separated list as EXPO_PUBLIC_PREMIUM_SUBSCRIPTION_IDS
#
# To deploy after editing function code:
#   supabase functions deploy ai-proxy
#   supabase functions deploy sync-apple-subscription
#
#
# EXPO_PUBLIC_GROUP_TYPE_PICKER=0